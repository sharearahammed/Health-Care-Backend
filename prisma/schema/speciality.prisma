model Speciality {
    id String @id @default(uuid(7))

    title       String  @unique @db.VarChar(100)
    description String? @db.Text
    icon        String? @db.VarChar(255)

    createdAt          DateTime           @default(now())
    updatedAt          DateTime           @updatedAt
    doctorSpecialities DoctorSpeciality[]

    isDeleted Boolean   @default(false)
    deletedAt DateTime?

    @@index([isDeleted], name: "idx_speciality_isdeleted")
    @@index([title], name: "idx_speciality_title")
    @@map("specialities ")
}

model DoctorSpeciality {
    id           String     @id @default(uuid(7))
    doctorId     String
    specialityId String
    doctor       Doctor     @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    speciality   Speciality @relation(fields: [specialityId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([doctorId, specialityId])
    @@index([doctorId], name: "idx_doctor_speciality_doctor_id")
    @@index([specialityId], name: "idx_doctor_speciality_speciality_id")
    @@map("doctor_specialities")
}
